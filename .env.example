# API 监听端口
PORT=8080

# 服务端固定使用的模型，不从客户端请求中接收
MODEL_NAME=nvidia/nemotron-nano-12b-v2-vl

# 上游提供方，目前固定为 nvidia
UPSTREAM_PROVIDER=nvidia

# NVIDIA OpenAI 兼容接口基础地址
UPSTREAM_BASE_URL=https://integrate.api.nvidia.com/v1

# NVIDIA 平台 API Key
NVIDIA_API_KEY=

# 你自己提供给调用方的服务密钥，客户端需放在 Authorization: Bearer <key>
USER_API_KEY=

# 单次请求超时时间，单位秒
REQUEST_TIMEOUT_SECONDS=45

# 启动后是否自动做一次上游模型连通性测试
STARTUP_SELF_TEST=true

# 启动自检超时时间，单位秒
SELF_TEST_TIMEOUT_SECONDS=30

# 是否启用模型 thinking；默认关闭以优先测试速度
ENABLE_THINKING=false

# 单机限流：每秒允许请求数
RATE_LIMIT_RPS=2

# 单机限流：突发桶容量
RATE_LIMIT_BURST=5

# 允许上传的最大图片字节数
MAX_IMAGE_BYTES=5242880

# 临时图片保存目录
TEMP_IMAGE_DIR=./tmp

# 日志级别，当前预留字段
LOG_LEVEL=info
